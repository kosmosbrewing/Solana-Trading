DATABASE_URL=postgresql://user:pass@localhost:5432/momentum_bot

# Jupiter
JUPITER_API_URL=https://quote-api.jup.ag/v6

# Notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading Mode
TRADING_MODE=paper         # "paper" or "live"
