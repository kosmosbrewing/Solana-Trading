# Solana
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
WALLET_PRIVATE_KEY=       # Base58 encoded, 트레이딩 전용 지갑만

# Data
BIRDEYE_API_KEY=
DATABASE_URL=postgresql://user:pass@localhost:5432/momentum_bot

# Jupiter
JUPITER_API_URL=https://api.jup.ag

# Notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading Mode
TRADING_MODE=paper         # "paper" or "live"
TARGET_PAIR_ADDRESS=       # legacy single-pair mode only

# ─── Risk (Group 2 subset) ───
MAX_RISK_PER_TRADE=0.01   # 1%
MAX_DAILY_LOSS=0.05        # 5%

# ─── Liquidity Parameters (Group 3) ───
MAX_SLIPPAGE=0.01          # 1%
MAX_POOL_IMPACT=0.02       # 2%
EMERGENCY_HAIRCUT=0.50     # 50%

# ─── Strategy Parameters (Group 2) ───
DEFAULT_TIMEFRAME=300      # 5분 (초 단위)
VOLUME_SPIKE_MULTIPLIER=3.0
VOLUME_SPIKE_LOOKBACK=20
MIN_BUY_RATIO=0.65
MIN_BREAKOUT_SCORE=50
TAKE_PROFIT_ATR_MULTIPLIER=2.0
TRAILING_STOP_ATR_MULTIPLIER=1.5
TIME_STOP_MINUTES=30
EXHAUSTION_THRESHOLD=2
PUMP_CONSECUTIVE_CANDLES=3
PUMP_MIN_PRICE_MOVE=0.05   # 5%

# ─── Universe Parameters (Group 1) ───
MIN_POOL_TVL=50000         # $50,000
MIN_TOKEN_AGE_SEC=86400    # 24h
MAX_TOP10_HOLDER_PCT=0.80  # 80%
MIN_DAILY_VOLUME=10000     # $10,000
MIN_TRADE_COUNT_24H=50
MAX_SPREAD_PCT=0.03        # 3%
MAX_WATCHLIST_SIZE=20
UNIVERSE_REFRESH_INTERVAL_MS=300000  # 5분

# Safety (legacy)
MIN_POOL_LIQUIDITY=50000
MIN_TOKEN_AGE_HOURS=24
MAX_HOLDER_CONCENTRATION=0.80

# ─── Scanner ───
SCANNER_ENABLED=true
SCANNER_TRENDING_POLL_MS=300000     # 5분 — DexScreener trending 갱신 주기
SCANNER_DEX_ENRICH_MS=300000        # 5분 — DexScreener pair 상세 보강 주기

# ─── Birdeye WebSocket (비활성 — Premium Plus 필요) ───
# BIRDEYE_WS_ENABLED=false          # 기본값 false, Strategy D 외에는 불필요
# BIRDEYE_WS_API_KEY=               # Premium Plus 전용

# ─── Helius Real-Time (비활성 — REFACTORING.md) ───
# Runtime contract:
# - REALTIME_ENABLED=true 이면 realtime 파이프라인이 켜진다.
# - 기본 WS URL은 SOLANA_RPC_URL에서 파생된다.
# - HELIUS_WS_URL은 WS URL override 용도다.
# - HELIUS_API_KEY는 문서/운영 참고용이며, 현재 런타임의 필수 스위치는 아니다.
HELIUS_API_KEY=
HELIUS_WS_URL=
REALTIME_ENABLED=false
REALTIME_PERSISTENCE_ENABLED=true
REALTIME_DATA_DIR=./data/realtime
REALTIME_OUTCOME_HORIZONS_SEC=30,60,180,300
REALTIME_PRIMARY_INTERVAL_SEC=15
REALTIME_CONFIRM_INTERVAL_SEC=60
REALTIME_VOLUME_SURGE_LOOKBACK=20
REALTIME_VOLUME_SURGE_MULTIPLIER=3.0
REALTIME_PRICE_BREAKOUT_LOOKBACK=20
REALTIME_CONFIRM_MIN_BARS=3
REALTIME_CONFIRM_MIN_CHANGE_PCT=0.02
REALTIME_COOLDOWN_SEC=300
REALTIME_MAX_SUBSCRIPTIONS=30
REALTIME_FALLBACK_CONCURRENCY=2
REALTIME_FALLBACK_RPS=4
REALTIME_FALLBACK_BATCH_SIZE=5
REALTIME_MAX_FALLBACK_QUEUE=1000
REALTIME_SL_MODE=atr
REALTIME_SL_ATR_MULTIPLIER=1.5
REALTIME_SL_SWING_LOOKBACK=5
REALTIME_TIME_STOP_MINUTES=15

# ─── Strategy D (비활성 — WS + Jito 전제) ───
# STRATEGY_D_ENABLED=false          # 기본값 false, Proven 단계 이후 활성화

# Execution
MAX_RETRIES=3
TX_TIMEOUT_MS=30000
COOLDOWN_MINUTES=30
MAX_CONSECUTIVE_LOSSES=3
