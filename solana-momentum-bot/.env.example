# Strategy
DEFAULT_TIMEFRAME=300      # 5분 (초 단위)
VOLUME_SPIKE_MULTIPLIER=3.0
VOLUME_SPIKE_LOOKBACK=20
PUMP_CONSECUTIVE_CANDLES=3
PUMP_MIN_PRICE_MOVE=0.05   # 5%

# Safety
