# ─── Tier 1: Secrets / Infrastructure ───
# shell profile `export` 또는 pm2 env로 주입 권장
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
WALLET_PRIVATE_KEY=                    # Base58 encoded, 트레이딩 전용 지갑만
DATABASE_URL=postgresql://user:pass@localhost:5432/momentum_bot
HELIUS_API_KEY=
HELIUS_WS_URL=
DEXSCREENER_API_KEY=
JUPITER_API_KEY=
JUPITER_API_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_USER_ID=
TWITTER_BEARER_TOKEN=
SANDBOX_WALLET_PRIVATE_KEY=
JITO_RPC_URL=

# ─── Tier 2: Operational Switches ───
# 배포 없이 토글 가능한 운영 스위치만 여기 관리
TRADING_MODE=paper
SCANNER_ENABLED=true
REALTIME_ENABLED=false
REALTIME_PERSISTENCE_ENABLED=true
REALTIME_TRIGGER_MODE=bootstrap
REALTIME_POOL_DISCOVERY_ENABLED=true
REALTIME_SEED_BACKFILL_ENABLED=false
SECURITY_GATE_ENABLED=true
QUOTE_GATE_ENABLED=true
PREFLIGHT_ENFORCE_GATE=false
USE_JITO_BUNDLES=false
USE_JUPITER_ULTRA=false
RUNNER_ENABLED=false
RUNNER_GRADE_B_ENABLED=false
RUNNER_CONCURRENT_ENABLED=false
DEGRADED_EXIT_ENABLED=false
KOL_HUNTER_YELLOW_ZONE_ENABLED=true
KOL_HUNTER_LIVE_MIN_INDEPENDENT_KOL=2
KOL_HUNTER_DEV_WALLET_LIVE_GATE_ENABLED=true
KOL_HUNTER_SMART_V3_VELOCITY_SCORE_THRESHOLD=5.0
KOL_HUNTER_SMART_V3_FRESH_WINDOW_SEC=60
KOL_HUNTER_SMART_V3_MAX_LAST_BUY_AGE_SEC=15
KOL_HUNTER_SMART_V3_PULLBACK_LIVE_ENABLED=false
KOL_HUNTER_SMART_V3_MIN_FRESH_AFTER_SELL_KOLS=2
KOL_HUNTER_YELLOW_ZONE_START_SOL=0.85
KOL_HUNTER_YELLOW_ZONE_PAPER_FALLBACK_BELOW_SOL=0.75
KOL_HUNTER_YELLOW_ZONE_MIN_INDEPENDENT_KOL=2
KOL_HUNTER_YELLOW_ZONE_MAX_RECENT_JUPITER_429=20
CANARY_AUTO_HALT_HYDRATE_ON_START=true
CANARY_AUTO_HALT_HYDRATE_LOOKBACK_HOURS=72
CANARY_AUTO_HALT_HYDRATE_SINCE=

# Phase B2 canary backdoor — EdgeTracker 오염 ledger 격리 구간 임시 우회
# DO NOT enable in production. A/B/C 검증 완료 후 반드시 false로 복귀.
BOT_BYPASS_EDGE_BLACKLIST=false

# ─── Tier 3: Trading Params ───
# 거래 파라미터는 src/utils/tradingParams.ts에서 코드로 관리
# git 추적 + 타입 안전 + 코드 리뷰를 위해 .env가 아닌 코드 변경으로 수정
