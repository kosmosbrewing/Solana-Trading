# Solana Momentum Bot production override profile.
# This file is safe to track in Git: do not put secrets here.
# Runtime secrets stay in VPS .env or shell profile:
# SOLANA_RPC_URL, WALLET_PRIVATE_KEY, DATABASE_URL, HELIUS_*, JUPITER_*, TELEGRAM_*.

TRADING_MODE=live
PREFLIGHT_ENFORCE_GATE=false
SCANNER_ENABLED=true
REALTIME_ENABLED=true
REALTIME_SEED_BACKFILL_ENABLED=false

PUREWS_LANE_ENABLED=true
PUREWS_LIVE_CANARY_ENABLED=false
PUREWS_SWING_V2_ENABLED=true
PUREWS_SWING_V2_LIVE_CANARY_ENABLED=false
PUREWS_SWING_V2_WALLET_MODE=main
PUREWS_WALLET_MODE=main
PUREWS_SURVIVAL_ALLOW_DATA_MISSING=false
PUREWS_V1_PER_PAIR_COOLDOWN_SEC=300

MIGRATION_LANE_ENABLED=true
MIGRATION_WALLET_MODE=main
CUPSEY_WALLET_MODE=main

WALLET_DELTA_DRIFT_WARN_SOL=0.03
CANARY_GLOBAL_CONCURRENCY_ENABLED=true
CANARY_GLOBAL_MAX_CONCURRENT=2

KOL_TRACKER_ENABLED=true
KOL_HUNTER_ENABLED=true
KOL_HUNTER_PAPER_ONLY=false
KOL_HUNTER_LIVE_CANARY_ENABLED=true
KOL_HUNTER_SHADOW_TRACK_INACTIVE=true
KOL_HUNTER_SHADOW_PAPER_TRADE_ENABLED=false
KOL_HUNTER_TAIL_RETAIN_ENABLED=true
KOL_HUNTER_TAIL_RETAIN_LIVE_ENABLED=false
KOL_HUNTER_PARTIAL_TAKE_ENABLED=true
KOL_HUNTER_CANARY_MAX_BUDGET_SOL=0.35
KOL_TX_FETCH_TIMEOUT_MS=10000
KOL_HUNTER_PARAMETER_VERSION=v1.0.0-paper-2026-04-25
KOL_HUNTER_SMART_V3_MIN_PULLBACK_PCT=0.20
KOL_HUNTER_QUICK_REJECT_FACTOR_COUNT=2
KOL_HUNTER_QUICK_REJECT_WINDOW_SEC=120
KOL_HUNTER_SMART_V3_PARAMETER_VERSION=smart-v3.0.0-paper-2026-04-26
KOL_HUNTER_SWING_V2_ENABLED=true
KOL_HUNTER_SWING_V2_PARAMETER_VERSION=swing-v2.0.0-paper-2026-04-26

KOL_HUNTER_ROTATION_V1_ENABLED=true
KOL_HUNTER_ROTATION_V1_LIVE_ENABLED=false
KOL_HUNTER_ROTATION_CHASE_TOPUP_PAPER_ENABLED=true
KOL_HUNTER_ROTATION_CHASE_TOPUP_LIVE_CANARY_ENABLED=true
KOL_HUNTER_ROTATION_CHASE_TOPUP_PARAMETER_VERSION=rotation-chase-topup-v1.0.0
KOL_HUNTER_ROTATION_CHASE_TOPUP_MIN_BUYS=2
KOL_HUNTER_ROTATION_CHASE_TOPUP_MIN_TOPUP_STRENGTH=0.08
KOL_HUNTER_ROTATION_CHASE_TOPUP_MAX_RECENT_SELL_SEC=60

EXECUTION_RR_REJECT=99.0
HELIUS_WATCHDOG_INTERVAL_MS=300000
HELIUS_RECONNECT_COOLDOWN_MS=300000
