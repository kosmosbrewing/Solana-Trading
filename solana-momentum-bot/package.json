{
  "name": "solana-momentum-bot",
  "version": "0.1.0",
  "description": "Solana DEX 마이크로캡 토큰 초봉 기반 모멘텀 브레이크아웃 자동매매 봇",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:ops": "node dist/ops/telegramControlBot.js",
    "dev": "ts-node src/index.ts",
    "dev:ops": "ts-node src/ops/telegramControlBot.ts",
    "migrate": "ts-node scripts/migrate.ts",
    "backtest": "ts-node scripts/backtest.ts",
    "paper-report": "ts-node scripts/paper-report.ts",
    "ops:check:ledger": "ts-node scripts/ledger-audit.ts",
    "ops:reconcile:wallet": "ts-node scripts/wallet-reconcile.ts",
    "ops:reconcile:live-assets": "ts-node scripts/live-asset-reconcile.ts",
    "ops:canary:eval": "ts-node scripts/canary-eval.ts",
    "kol:shadow-eval": "ts-node scripts/kol-shadow-eval.ts",
    "kol:paper-arm-report": "ts-node scripts/kol-paper-arm-report.ts",
    "kol:live-canary-report": "ts-node scripts/kol-live-canary-report.ts",
    "kol:policy-report": "ts-node scripts/kol-policy-report.ts",
    "kol:rotation-report": "ts-node scripts/rotation-lane-report.ts",
    "kol:capitulation-report": "ts-node scripts/capitulation-rebound-report.ts",
    "kol:smart-v3-evidence-report": "ts-node scripts/smart-v3-evidence-report.ts",
    "kol:historical-loss-report": "ts-node scripts/historical-loss-miner.ts",
    "kol:transfer-backfill": "ts-node scripts/kol-transfer-backfill.ts",
    "kol:transfer-refresh": "bash scripts/kol-transfer-refresh.sh",
    "kol:transfer-report": "ts-node scripts/kol-transfer-posterior-report.ts",
    "kol:live-equivalence-report": "ts-node scripts/kol-live-equivalence-report.ts",
    "purews:botflow-report": "ts-node scripts/pure-ws-botflow-report.ts",
    "purews:botflow-paper": "ts-node scripts/pure-ws-botflow-report.ts",
    "ops:trade-markout-audit": "ts-node scripts/trade-markout-audit.ts",
    "lane:reconcile": "ts-node scripts/reconcile-lane-outcomes.ts",
    "lane:edge-report": "ts-node scripts/lane-edge-report.ts",
    "ops:burst:replay": "ts-node scripts/wsBurstPaperReplay.ts",
    "ops:ruin:simulate": "ts-node scripts/ruinProbability.ts",
    "ops:cleanup:stuck": "ts-node scripts/stuck-positions-cleanup.ts",
    "ops:sanitize:hwm": "ts-node scripts/sanitize-oxidized-hwm.ts",
    "ops:check:helius": "ts-node scripts/ops-helius-check.ts",
    "ops:helius-credit-report": "ts-node scripts/helius-credit-attribution-report.ts",
    "realtime-shadow": "ts-node scripts/realtime-shadow-runner.ts",
    "ops:check": "ts-node scripts/ops-realtime-check.ts",
    "ops:check:sparse": "ts-node scripts/ops-sparse-check.ts",
    "ops:refresh:vps-analysis": "bash scripts/refresh-vps-analysis.sh",
    "vps:shadow": "bash scripts/vps-realtime-shadow.sh",
    "deploy:vps": "bash scripts/deploy.sh",
    "deploy:preflight": "bash scripts/deploy-preflight.sh",
    "restart:bot-ops": "bash scripts/restart-bot-and-ops.sh",
    "docs:lint": "node scripts/docs-lint.js && bash scripts/check-docs-freshness.sh",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "test": "jest --config jest.config.cjs",
    "env:generate": "ts-node scripts/env-catalog.ts --write",
    "env:check": "ts-node scripts/env-catalog.ts --check",
    "check:fast": "npm run typecheck && npm run typecheck:scripts && npm run env:check && jest --config jest.config.cjs --silent",
    "check": "npm run typecheck && npm run typecheck:scripts && npm run env:check && npm run test",
    "check:strict": "npm run check && npm run lint && npm run docs:lint"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "axios": "^1.7.0",
    "bignumber.js": "^9.1.2",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.0",
    "pg": "^8.13.0",
    "winston": "^3.14.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true
}
